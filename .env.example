# NATS connection
NATS_URL=nats://localhost:4222

# LLM configuration (shared defaults — all agents use these unless overridden)
OPENROUTER_API_KEY=your-openrouter-api-key
DEFAULT_MODEL=google/gemini-2.0-flash-001

# Per-agent overrides (optional — uncomment to override shared defaults)
# BAKER_API_KEY=agent-specific-key
# BAKER_MODEL=anthropic/claude-3.5-haiku
# FARMER_API_KEY=agent-specific-key
# FARMER_MODEL=anthropic/claude-3.5-haiku
# WOODCUTTER_API_KEY=agent-specific-key
# WOODCUTTER_MODEL=anthropic/claude-3.5-haiku
# MERCHANT_API_KEY=agent-specific-key
# MERCHANT_MODEL=anthropic/claude-3.5-haiku
